# ─────────────────────────────────────────────────
# Servidor
# ─────────────────────────────────────────────────
NODE_ENV=development
HOST=0.0.0.0
PORT=3333

# ─────────────────────────────────────────────────
# Autenticação
# ─────────────────────────────────────────────────
# Token Bearer para autenticar chamadas à API
API_TOKEN=seu-token-aqui

# Token separado para acesso à página do QR code no browser
QR_ACCESS_TOKEN=seu-token-qr-aqui

# ─────────────────────────────────────────────────
# Banco de dados (PostgreSQL)
# ─────────────────────────────────────────────────
DATABASE_URL=postgresql://usuario:senha@host:5432/nome_do_banco

# ─────────────────────────────────────────────────
# WhatsApp
# ─────────────────────────────────────────────────
# Número máximo de tentativas de reconexão automática
MAX_RETRIES=5

# Intervalo base entre tentativas de reconexão (em ms)
# O intervalo real é RECONNECT_INTERVAL_MS * número_da_tentativa (max 60s)
RECONNECT_INTERVAL_MS=5000

# Diretório onde os arquivos de autenticação das sessões são salvos
SESSIONS_DIR=./sessions

# ─────────────────────────────────────────────────
# Webhook (mensagens recebidas)
# ─────────────────────────────────────────────────
# URL para onde as mensagens recebidas serão encaminhadas (deixe em branco para desabilitar)
WEBHOOK_URL=

# Número máximo de tentativas de envio do webhook
WEBHOOK_MAX_RETRIES=3

# Delay base entre tentativas do webhook (em ms, duplica a cada falha)
WEBHOOK_RETRY_DELAY_MS=1000

# ─────────────────────────────────────────────────
# Telegram (alertas de sessão)
# ─────────────────────────────────────────────────
# Token do bot do Telegram (deixe em branco para desabilitar alertas)
TELEGRAM_TOKEN=

# ID do chat/grupo do Telegram que receberá os alertas
TELEGRAM_CHAT_ID=
