{
  "name": "fastzap-whatsapp-api-v2",
  "version": "2.0.0",
  "description": "WhatsApp API gateway com Clean Architecture - Fastify + Baileys",
  "type": "module",
  "main": "src/main.js",
  "scripts": {
    "start": "node src/main.js",
    "dev": "node --watch src/main.js",
    "migrate": "node-pg-migrate up --migrations-dir migrations --migration-file-language js",
    "migrate:down": "node-pg-migrate down --migrations-dir migrations --migration-file-language js",
    "migrate:create": "node-pg-migrate create --migrations-dir migrations --migration-file-language js"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@whiskeysockets/baileys": "^7.0.0-rc.6",
    "axios": "^1.11.0",
    "dotenv": "^17.2.1",
    "fastify": "^5.3.2",
    "node-cleanup": "^2.1.2",
    "node-pg-migrate": "^7.9.1",
    "pino": "^9.7.0",
    "pino-pretty": "^13.0.0",
    "postgres": "^3.4.5",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "eslint": "^9.28.0",
    "prettier": "^3.5.3"
  }
}
